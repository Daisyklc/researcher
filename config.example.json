{
  "active_provider": "deepseek",
  "providers": {
    "deepseek": {
      "base_url": "https://api.deepseek.com",
      "api_key_env": "DEEPSEEK_API_KEY",
      "api_key": "在此填入 DeepSeek Key(留空则回退读取 api_key_env 环境变量)",
      "models": {
        "fast": "deepseek-chat",
        "standard": "deepseek-chat",
        "strong": "deepseek-chat",
        "reasoning": "deepseek-reasoner"
      }
    },
    "qwen": {
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "api_key_env": "DASHSCOPE_API_KEY",
      "api_key": "在此填入 阿里云百炼(DashScope) Key(留空则回退读取 api_key_env 环境变量)",
      "models": {
        "fast": "qwen-turbo",
        "standard": "qwen-plus",
        "strong": "qwen-max",
        "reasoning": "qwq-plus",
        "reasoning_32b": "qwq-32b",
        "vision": "qwen-vl-max",
        "video": "qwen-vl-max-latest",
        "omni": "qwen-omni-turbo"
      }
    }
  },
  "roles": {
    "intent_model": "fast",
    "discovery_model": "standard",
    "closed_model": "fast",
    "analysis_model": "reasoning",
    "summary_model": "standard"
  }
}
